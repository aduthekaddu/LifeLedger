NODE_ENV=development
PORT=5000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifeledger

# Use a generated value with at least 32 characters.
JWT_SECRET=replace-with-a-generated-64-character-secret
JWT_EXPIRES_IN=8h

CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

UPLOAD_DIR=./private-uploads
MAX_FILE_SIZE_BYTES=10485760
EMERGENCY_ACCESS_TTL_MINUTES=120
LOG_LEVEL=info
